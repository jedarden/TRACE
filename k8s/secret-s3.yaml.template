---
# Secret: S3 credentials for TRACE flusher
# This is a template - encrypt with kubeseal for production use
apiVersion: v1
kind: Secret
metadata:
  name: trace-s3-credentials
  namespace: trace
type: Opaque
stringData:
  bucket: "your-trace-bucket"
  region: "us-east-1"
  access-key-id: "your-access-key-id"
  secret-access-key: "your-secret-access-key"
